# LLM Providers — copy this file to .env and fill in your keys
# At least ONE of the following is required for the Skill Recommender

# Google Gemini (recommended — free tier available)
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenRouter (optional — routes to any provider)
OPENROUTER_API_KEY=

# DeepWiki Open (self-hosted Docker)
DEEPWIKI_URL=http://localhost:3000

# LLM Provider preference: gemini | openai | claude | openrouter
LLM_PROVIDER=gemini
